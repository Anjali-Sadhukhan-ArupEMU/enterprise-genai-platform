# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME="Enterprise GenAI Platform"
APP_VERSION="0.1.0"
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Entra ID (fill in from Azure portal) ──────────────────────────────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_AUTHORITY=

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
# Name of the deployment you created in the portal/CLI (e.g. "gpt-4o-mini-test").
# When set, the platform routes ALL traffic to this single deployment.
# Recommended for $-controlled testing — pick ONE cheap model.
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini-test
# Set true to force Managed Identity even if an API key is present.
# In production (App Service / Container Apps), leave true and clear the key.
AZURE_OPENAI_USE_MANAGED_IDENTITY=true
# API key — local dev only. Leave EMPTY when using Managed Identity / az login.
AZURE_OPENAI_API_KEY=

# ── Azure AI Foundry project ──────────────────────────────────────────────────
# Used by azure-ai-projects / azure-ai-inference SDKs for non-OpenAI models
# (Llama, Mistral, DeepSeek) and for project-level tools. OpenAI calls still
# go through AZURE_OPENAI_ENDPOINT above.
FOUNDRY_PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<project-name>

# ── Grounding with Bing Search (gated web search) ─────────────────────────────
# Master switch. When false, web search is disabled regardless of persona/gate.
WEB_SEARCH_ENABLED=true
# Foundry connection resource id for the Bing.Grounding account. Provisioned by
# infra/bing.bicep — leave EMPTY to fall back to the mock provider in dev.
BING_GROUNDING_CONNECTION_ID=
# Foundry project endpoint the agents SDK talks to (same as FOUNDRY_PROJECT_ENDPOINT).
BING_GROUNDING_ENDPOINT=
# Max grounding results injected into the prompt.
WEB_SEARCH_MAX_RESULTS=4

# ── Usage dashboard ──────────────────────────────────────────────────────────
# Monthly budget shown as the progress-bar denominator. Set to your real
# MSDN remaining credit (check https://account.azure.com/Subscriptions).
MONTHLY_BUDGET_INR=12500
# USD→INR rate for converting Azure's USD-priced model costs into INR.
USD_TO_INR=83

# ── Cosmos DB (leave empty for in-memory dev mode) ────────────────────────────
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=genai_platform
COSMOS_CONVERSATIONS_CONTAINER=conversations

# ── ADLS (leave empty for local file logging) ────────────────────────────────
ADLS_ACCOUNT_URL=
ADLS_AUDIT_CONTAINER=audit
ADLS_ANALYTICS_CONTAINER=analytics

# ── Content Safety (Phase 2) ─────────────────────────────────────────────────
CONTENT_SAFETY_ENDPOINT=
CONTENT_SAFETY_KEY=

# ── Redis (Phase 2 semantic cache) ───────────────────────────────────────────
REDIS_URL=

# ── Routing ──────────────────────────────────────────────────────────────────
ROUTING_CONFIG_PATH=config/routing_config.json
