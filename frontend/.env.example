# Vite-injected env vars must start with VITE_ to be exposed to the client.
# Values are inlined at build / dev-server start time — restart vite after editing.

# Show or hide the sidebar Usage panel. true | false (default: true)
VITE_USAGE_DASHBOARD_ENABLED=true

# ── Entra ID SSO ────────────────────────────────────────────────────────────
# Leave blank for local mock auth (Admin/User buttons). Set the client ID to
# enable real "Sign in with Microsoft" SSO. These are public identifiers.
# To test real SSO locally, create frontend/.env.local with:
#   VITE_ENTRA_CLIENT_ID=78ff835c-ce1e-4b0e-a73c-f782c00efa3f
#   VITE_ENTRA_TENANT_ID=ba461c38-ace0-48a9-a880-b7f5a6b8f450
#   VITE_REDIRECT_URI=http://localhost:3000
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=
VITE_REDIRECT_URI=
